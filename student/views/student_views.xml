<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_student_student_list" model="ir.ui.view">
            <field name="name">student.student.list</field>
            <field name="model">student.student</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="age"/>
                    <field name="email"/>
                    <field name="phone"/>
                </list>
            </field>
        </record>

        <record id="action_student_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">student.student</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="student_student_menu_root" name="Students"/>
        <menuitem id="student_studen_menu" name="Students" parent="student_student_menu_root"
        action="action_student_student"/>
    </data>
</odoo>